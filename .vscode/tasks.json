{
  // Build / upload tasks for arduino-cli.
  //
  // TWO targets share this repo, selected only by which task you run:
  //   * "Arduino: Build [& Upload]"            -> ESP32 Cheap Yellow Display (plain ESP32), COM4.
  //   * "Arduino: Build [& Upload] (JC4827W543)" -> Guition JC4827W543 (ESP32-S3), COM5.
  //
  // The JC4827W543 tasks pass -DBOARD_JC4827W543 (via compiler.cpp.extra_flags) which flips
  // board.h to the ESP32-S3 / Arduino_GFX / USB / I2S-amp configuration. The CYD tasks pass
  // no such define, so board.h defaults to the original CYD setup and that firmware is unchanged.
  //
  // Run with: Terminal > Run Task…  (Build is the default build task: Ctrl+Shift+B)
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Arduino: Build",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "--fqbn",
        "esp32:esp32:esp32:PSRAM=disabled,PartitionScheme=huge_app,CPUFreq=240,FlashMode=qio,FlashFreq=80,FlashSize=4M,UploadSpeed=921600,LoopCore=1,EventsCore=1,DebugLevel=none",
        "--verbose",
        "--build-property",
        "compiler.optimization_flags=-O2",
        "${workspaceFolder}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Arduino: Build & Upload",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "upload",
        "-p",
        "COM4",
        "--fqbn",
        "esp32:esp32:esp32:PSRAM=disabled,PartitionScheme=huge_app,CPUFreq=240,FlashMode=qio,FlashFreq=80,FlashSize=4M,UploadSpeed=921600,LoopCore=1,EventsCore=1,DebugLevel=none",
        "--verbose",
        "${workspaceFolder}"
      ],
      "dependsOn": "Arduino: Build",
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Arduino: Build (JC4827W543)",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "--fqbn",
        "esp32:esp32:esp32s3:PSRAM=opi,PartitionScheme=huge_app,CPUFreq=240,FlashMode=qio,FlashSize=4M,UploadSpeed=921600,USBMode=default,CDCOnBoot=default,DebugLevel=none",
        "--verbose",
        "--build-property",
        "compiler.optimization_flags=-O2",
        "--build-property",
        "compiler.cpp.extra_flags=-DBOARD_JC4827W543",
        "${workspaceFolder}"
      ],
      "group": "build",
      "problemMatcher": ["$gcc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Arduino: Build & Upload (JC4827W543)",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "upload",
        "-p",
        "COM5",
        "--fqbn",
        "esp32:esp32:esp32s3:PSRAM=opi,PartitionScheme=huge_app,CPUFreq=240,FlashMode=qio,FlashSize=4M,UploadSpeed=921600,USBMode=default,CDCOnBoot=default,DebugLevel=none",
        "--verbose",
        "${workspaceFolder}"
      ],
      "dependsOn": "Arduino: Build (JC4827W543)",
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      // Guition JC1060P470 (ESP32-P4). ISOLATED toolchain: ARDUINO_DIRECTORIES_DATA/USER point at a
      // P4-only sketchbook+core dir OUTSIDE the repo (~/.emu6502-p4) so this build uses Arduino-ESP32
      // core 3.x (IDF 5.x) WITHOUT touching the global 2.0.17 the CYD/S3 builds use. It MUST be outside
      // the sketch folder, else arduino-cli tries to copy the deep core tree and overruns the Windows
      // 260-char path limit. One-time setup (see README, "P4 build"):
      //   $env:ARDUINO_DIRECTORIES_DATA="$HOME/.emu6502-p4/data"
      //   $env:ARDUINO_DIRECTORIES_USER="$HOME/.emu6502-p4/user"
      //   arduino-cli core update-index; arduino-cli core install esp32:esp32@3.3.10
      //   arduino-cli lib install "GFX Library for Arduino"   (USB host is deferred on P4 -> no EspUsbHost)
      // Confirm the exact FQBN menu options/values for your installed core with:
      //   arduino-cli board details --fqbn esp32:esp32:esp32p4
      "label": "Arduino: Build (JC1060P470)",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "--fqbn",
        "esp32:esp32:esp32p4:PSRAM=enabled,FlashSize=16M,PartitionScheme=huge_app,DebugLevel=none",
        "--verbose",
        "--build-property",
        "compiler.optimization_flags=-O2",
        "--build-property",
        "compiler.cpp.extra_flags=-DBOARD_JC1060P470",
        "${workspaceFolder}"
      ],
      "options": {
        "env": {
          "ARDUINO_DIRECTORIES_DATA": "${userHome}/.emu6502-p4/data",
          "ARDUINO_DIRECTORIES_USER": "${userHome}/.emu6502-p4/user"
        }
      },
      "group": "build",
      "problemMatcher": ["$gcc"],
      "presentation": { "reveal": "always", "panel": "shared", "clear": true }
    },
    {
      "label": "Arduino: Build & Upload (JC1060P470)",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "upload",
        "-p",
        "COM6",
        "--fqbn",
        "esp32:esp32:esp32p4:PSRAM=enabled,FlashSize=16M,PartitionScheme=huge_app,DebugLevel=none",
        "--verbose",
        "${workspaceFolder}"
      ],
      "options": {
        "env": {
          "ARDUINO_DIRECTORIES_DATA": "${userHome}/.emu6502-p4/data",
          "ARDUINO_DIRECTORIES_USER": "${userHome}/.emu6502-p4/user"
        }
      },
      "dependsOn": "Arduino: Build (JC1060P470)",
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "presentation": { "reveal": "always", "panel": "shared", "clear": true }
    },
    {
      // DESKTOP (SDL2) debug build via MSYS2 MinGW32. Used as the preLaunchTask for F5
      // (.vscode/launch.json). Configures CMake on first run, then builds build/emu8.exe.
      "label": "desktop: build",
      "type": "process",
      "command": "C:\\msys64\\usr\\bin\\bash.exe",
      "args": [
        "-lc",
        "cd /c/Users/lucia/repos/emu8 && cmake -G 'Unix Makefiles' -S . -B build -DEMU_M32=OFF -DCMAKE_BUILD_TYPE=Debug && make -C build -j4"
      ],
      "options": { "env": { "MSYSTEM": "MINGW32", "CHERE_INVOKING": "1" } },
      "group": "build",
      "problemMatcher": ["$gcc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
